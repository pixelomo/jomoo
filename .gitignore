# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep the example template, ignore everything with real secrets
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# sanity
.sanity/

# vercel
.vercel

# claude code
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts
